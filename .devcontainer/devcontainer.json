{
  "name": "Recruit Copilot",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "postCreateCommand": "npm install",
  "postStartCommand": "node scripts/codespace-start.mjs",
  "postAttachCommand": "node scripts/codespace-start.mjs",
  "forwardPorts": [3055],
  "portsAttributes": {
    "3055": {
      "label": "Recruit Copilot App",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    }
  },
  "customizations": {
    "codespaces": {
      "openFiles": []
    },
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteUser": "node"
}
