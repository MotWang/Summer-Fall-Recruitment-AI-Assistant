{
  "name": "recruit-copilot",
  "version": "0.1.0",
  "private": true,
  "description": "2027 Summer & Fall Recruitment Assistant — 本地优先的投递、面试、简历与面经助手",
  "homepage": "https://motwang.github.io/Summer-Fall-Recruitment-AI-Assistant/",
  "scripts": {
    "dev": "next dev -p 3055",
    "dev:clean": "rm -rf .next && next dev -p 3055",
    "prebuild": "node scripts/prebuild-check.mjs",
    "build": "next build",
    "start": "next start -p 3055",
    "serve": "node scripts/serve.mjs",
    "doctor": "node scripts/doctor.mjs",
    "restart": "node scripts/kill-port.mjs 3055 && node scripts/serve.mjs",
    "lint": "next lint",
    "db:reset": "node scripts/reset-db.mjs",
    "db:seed": "node scripts/seed.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "next": "14.2.15",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.10",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.27.3"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
